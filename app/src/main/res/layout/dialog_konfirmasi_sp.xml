<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_form_header"
        android:gravity="center_vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KONFIRMASI&#10;PEMBUATAN SURAT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="22sp" />

    </LinearLayout>

    <!-- ISI -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RINGKASAN PESANAN"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvKonfirmasiId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID Surat : SP001"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvKonfirmasiJenis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Kain : Denim"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvKonfirmasiJumlah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jumlah Produksi : 150 Meter"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvKonfirmasiDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline Produksi : 2026-06-17"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apakah Anda yakin ingin membuat Surat Perintah Produksi untuk pesanan ini?"
            android:textSize="15sp"
            android:textColor="#444444"/>

    </LinearLayout>

</LinearLayout>