<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etItemName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jenis Kain (Katun, Polyester, Denim, dll)"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext" />

    <EditText
        android:id="@+id/etQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jumlah (meter)"
        android:inputType="number"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext" />

    <EditText
        android:id="@+id/etUnit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Satuan (meter, roll, yard)"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext"
        android:text="meter" />

    <EditText
        android:id="@+id/etSupplier"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Supplier / Pemasok"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext" />

    <EditText
        android:id="@+id/etBatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nomor Batch / Lot"
        android:padding="12dp"
        android:background="@drawable/bg_edittext" />

</LinearLayout>