<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_form_header"
            android:gravity="center_vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MULAI&#10;PRODUKSI"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ISI FORM -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="650dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- DATA SP -->

            <TextView
                android:id="@+id/tvSpId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SP001"
                android:textColor="#1565C0"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JENIS KAIN"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvJenisKainInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Denim"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANJANG SURAT PERINTAH"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPanjangInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150 Meter"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEADLINE PRODUKSI"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDeadlineInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-06-20"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="30dp" />

            <!-- JENIS PRODUKSI -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JENIS PRODUKSI"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spJenisProduksi"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvJenisError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis kain tidak sesuai surat perintah"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="28dp" />

            <!-- PANJANG PRODUKSI -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANJANG PRODUKSI"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etPanjangProduksi"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_edittext"
                android:hint="Masukkan panjang produksi"
                android:inputType="number"
                android:padding="14dp" />

            <TextView
                android:id="@+id/tvPanjangError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp" />

            <!-- CATATAN -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATATAN PRODUKSI"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_edittext"
                android:gravity="top"
                android:hint="Masukkan catatan produksi"
                android:padding="14dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>