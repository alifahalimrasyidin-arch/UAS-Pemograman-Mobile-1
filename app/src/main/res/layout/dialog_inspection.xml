<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etInspectQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jumlah Kain yang Diinspeksi (meter)"
        android:inputType="number"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hasil Inspeksi:"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgInspectResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rbPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Lulus"
            android:textColor="#4CAF50"
            android:layout_marginEnd="24dp" />

        <RadioButton
            android:id="@+id/rbRepair"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 Perbaikan"
            android:textColor="#FF9800"
            android:layout_marginEnd="24dp" />

        <RadioButton
            android:id="@+id/rbFail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❌ Gagal"
            android:textColor="#F44336" />
    </RadioGroup>

    <EditText
        android:id="@+id/etInspectNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Catatan Inspeksi (warna, ketebalan, kerapatan, cacat)"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_edittext"
        android:minLines="3"
        android:gravity="top" />

    <EditText
        android:id="@+id/etGrade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Grade Kain (A / B / C)"
        android:padding="12dp"
        android:background="@drawable/bg_edittext" />

</LinearLayout>