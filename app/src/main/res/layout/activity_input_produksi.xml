<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_form_header"
            android:gravity="center_vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INPUT&#10;PRODUKSI"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- CARD DATA SP -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- HEADER CARD -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_form_header"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATA SURAT PERINTAH"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                </LinearLayout>

                <!-- ISI -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvSpId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SP001"
                        android:textColor="#1565C0"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JENIS KAIN"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvJenisKainInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Polyester"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PANJANG SURAT PERINTAH"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvPanjangInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="150 Meter"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEADLINE PRODUKSI"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvDeadlineInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026-06-30"
                        android:textSize="16sp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- FORM PRODUKSI -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANJANG PRODUKSI"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etPanjangProduksi"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_edittext"
                android:hint="Masukkan panjang produksi"
                android:inputType="number"
                android:padding="14dp"/>

            <TextView
                android:id="@+id/tvPanjangError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATATAN PRODUKSI"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_edittext"
                android:gravity="top"
                android:hint="Masukkan catatan produksi"
                android:padding="14dp"/>

            <Button
                android:id="@+id/btnSimpanProduksi"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="30dp"
                android:text="SIMPAN PRODUKSI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>