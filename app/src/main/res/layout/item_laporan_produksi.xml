<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardLaporan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="7dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_form_header"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvSpId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="SP001"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/imgStatus"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/checkbox_on_background"
                android:tint="#FFFFFF"/>

        </RelativeLayout>

        <!-- CONTENT -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Jenis -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JENIS KAIN"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvJenisKain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Polyester"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"/>

            <!-- Jumlah -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JUMLAH PRODUKSI"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvJumlah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250 Meter"
                android:textSize="16sp"
                android:layout_marginBottom="14dp"/>

            <!-- Deadline -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEADLINE"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-06-28"
                android:textSize="16sp"
                android:layout_marginBottom="14dp"/>

            <!-- Divider -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="14dp"/>

            <!-- STATUS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_status_hijau"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="SELESAI PRODUKSI"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Tanggal -->

            <TextView
                android:id="@+id/tvTanggalProduksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tanggal Produksi : 2026-06-24"
                android:textSize="15sp"
                android:layout_marginTop="18dp"/>

            <!-- Petugas -->

            <TextView
                android:id="@+id/tvPetugas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Petugas : Alif"
                android:textSize="15sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>