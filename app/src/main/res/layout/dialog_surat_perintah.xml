<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="@drawable/bg_form_header"
            android:gravity="center_vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUAT SURAT&#10;PERINTAH PRODUKSI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp" />

        </LinearLayout>

        <!-- ISI FORM -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="650dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ID SURAT -->

            <TextView
                android:id="@+id/tvSpId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ID Surat : SP001"
                android:textColor="#1565C0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp" />

            <!-- JENIS KAIN -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JENIS KAIN"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/spJenisKain"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="40dp" />

            <!-- PANJANG KAIN -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANJANG KAIN"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etPanjangKain"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_edittext"
                android:hint="Masukkan panjang kain"
                android:inputType="number"
                android:padding="14dp" />

            <TextView
                android:id="@+id/tvPanjangError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E53935"
                android:textSize="11sp"
                android:visibility="gone"
                android:layout_marginBottom="28dp" />

            <!-- DEADLINE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEADLINE PRODUKSI"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etDeadline"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_edittext"
                android:hint="Pilih deadline produksi"
                android:focusable="false"
                android:clickable="true"
                android:padding="14dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>