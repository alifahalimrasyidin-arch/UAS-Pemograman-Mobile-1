<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_form_header"
        android:gravity="center_vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MONITORING HASIL QC"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="22sp"/>

    </LinearLayout>

    <!-- PENCARIAN -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <EditText
            android:id="@+id/etCariQC"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Cari No QC / SP ID"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:inputType="text"/>

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp"/>

        <Button
            android:id="@+id/btnCariQC"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="CARI"/>

    </LinearLayout>

    <!-- FILTER GRADE -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Grade"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spGradeFilter"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext"/>

    </LinearLayout>

    <!-- RINGKASAN -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvJumlahLaporanQC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total Data QC : 0"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvTotalGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grade A : 0"
            android:textStyle="bold"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- GARIS PEMBATAS -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="#DADADA"/>

    <!-- LIST LAPORAN QC -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLaporanQC"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>