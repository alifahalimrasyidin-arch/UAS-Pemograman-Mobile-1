<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#4A90E2"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 LAPOR HASIL PRODUKSI"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🆔 Nomor SP"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSPId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Contoh: SP-001"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:textSize="14sp"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📏 Jumlah Produksi"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etQuantity"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Jumlah (meter)"
            android:inputType="number"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext_modern"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Catatan / Kendala"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Isikan catatan jika ada kendala..."
            android:padding="12dp"
            android:gravity="top"
            android:background="@drawable/bg_edittext_modern"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>